{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "github>DenuxPlays/renovate-config:all.json5"
    ],
    "ignorePaths": [
        "frontend/android/",
        "frontend/macos/",
        "frontend/ios/"
    ],
    "packageRules": [
        {
            "matchFileNames": ["frontend/pubspec.yaml"],
            "matchPackageNames": ["forui", "forui_hooks"],
            "groupName": "forui"
        }
    ]
}
